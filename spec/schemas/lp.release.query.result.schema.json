{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.release.query.result.schema.json",
  "title": "lp.release.query.result@0.1.0",
  "description": "Release candidate or promoted release view.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "release_id",
    "workload_id",
    "status",
    "pack_digest",
    "created_unix_ms",
    "updated_unix_ms"
  ],
  "properties": {
    "schema_version": {
      "const": "lp.release.query.result@0.1.0"
    },
    "release_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "workload_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "status": {
      "type": "string",
      "enum": [
        "drafted",
        "submitted",
        "under_review",
        "approved",
        "rejected",
        "deploying",
        "deployed",
        "rolled_back",
        "superseded"
      ]
    },
    "pack_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "target_id": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "evidence_count": {
      "type": "integer",
      "minimum": 0,
      "default": 0
    },
    "latest_decision_id": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "created_unix_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "updated_unix_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    }
  }
}
