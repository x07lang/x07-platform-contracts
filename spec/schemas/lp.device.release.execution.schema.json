{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.device.release.execution.schema.json",
  "title": "lp.device.release.execution@0.2.0",
  "description": "Run record for executing an lp.device.release.plan and recording provider-neutral release state, readiness, and the latest native health rollup.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "exec_id",
    "plan_id",
    "run_id",
    "created_unix_ms",
    "status",
    "steps",
    "meta"
  ],
  "properties": {
    "schema_version": { "const": "lp.device.release.execution@0.2.0" },
    "exec_id": { "$ref": "#/$defs/id" },
    "plan_id": { "$ref": "#/$defs/id" },
    "run_id": { "$ref": "#/$defs/id" },
    "created_unix_ms": { "$ref": "#/$defs/unix_ms" },
    "status": { "$ref": "#/$defs/exec_status" },
    "plan": {
      "oneOf": [{ "$ref": "#/$defs/plan_ref" }, { "type": "null" }],
      "default": null
    },
    "steps": {
      "type": "array",
      "maxItems": 4096,
      "items": { "$ref": "#/$defs/exec_step" },
      "default": []
    },
    "meta": {
      "type": "object",
      "required": [
        "provider_kind",
        "distribution_lane",
        "target",
        "package_digest",
        "native_summary",
        "release_readiness",
        "current_state",
        "current_rollout_percent",
        "latest_metrics_snapshot",
        "latest_slo_eval_report",
        "latest_eval_outcome",
        "latest_store_release_id",
        "latest_native_health_rollup",
        "latest_native_incident_id",
        "latest_regression_id",
        "latest_regression_status"
      ],
      "additionalProperties": true,
      "properties": {
        "provider_kind": { "$ref": "#/$defs/provider_kind" },
        "distribution_lane": {
          "type": "string",
          "enum": ["beta", "production"]
        },
        "target": { "$ref": "#/$defs/release_target" },
        "package_digest": { "$ref": "#/$defs/digest_ref" },
        "native_summary": { "$ref": "#/$defs/native_summary" },
        "release_readiness": { "$ref": "#/$defs/release_readiness" },
        "current_state": {
          "type": "string",
          "enum": [
            "draft",
            "review",
            "available",
            "in_progress",
            "paused",
            "halted",
            "completed",
            "rolled_back"
          ]
        },
        "current_rollout_percent": {
          "oneOf": [
            { "type": "integer", "minimum": 0, "maximum": 100 },
            { "type": "null" }
          ],
          "default": null
        },
        "latest_metrics_snapshot": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "digest"],
              "properties": {
                "kind": { "const": "x07.metrics.snapshot@0.1.0" },
                "digest": { "$ref": "#/$defs/digest_ref" },
                "label": { "type": "string", "maxLength": 256 }
              }
            },
            { "type": "null" }
          ],
          "default": null
        },
        "latest_slo_eval_report": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "digest"],
              "properties": {
                "kind": { "const": "x07.wasm.slo.eval.report@0.1.0" },
                "digest": { "$ref": "#/$defs/digest_ref" },
                "label": { "type": "string", "maxLength": 256 }
              }
            },
            { "type": "null" }
          ],
          "default": null
        },
        "latest_eval_outcome": {
          "type": "string",
          "enum": ["ok", "fail", "inconclusive", "none"],
          "default": "none"
        },
        "latest_store_release_id": {
          "oneOf": [
            { "type": "string", "minLength": 1, "maxLength": 256 },
            { "type": "null" }
          ],
          "default": null
        },
        "latest_native_health_rollup": {
          "oneOf": [
            { "$ref": "#/$defs/native_health_rollup" },
            { "type": "null" }
          ],
          "default": null
        },
        "latest_native_incident_id": {
          "oneOf": [
            { "$ref": "#/$defs/id" },
            { "type": "null" }
          ],
          "default": null
        },
        "latest_regression_id": {
          "oneOf": [
            { "$ref": "#/$defs/id" },
            { "type": "null" }
          ],
          "default": null
        },
        "latest_regression_status": { "$ref": "#/$defs/regression_status" }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "bytes_len": { "type": "integer", "minimum": 0 },
    "unix_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991,
      "description": "Unix timestamp in milliseconds (non-negative, JS-safe integer)."
    },
    "digest_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256", "bytes_len"],
      "properties": {
        "sha256": { "$ref": "#/$defs/sha256" },
        "bytes_len": { "$ref": "#/$defs/bytes_len" }
      }
    },
    "schema_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*@[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "artifact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["digest"],
      "properties": {
        "kind": { "$ref": "#/$defs/schema_id" },
        "digest": { "$ref": "#/$defs/digest_ref" },
        "label": { "type": "string", "maxLength": 256 }
      }
    },
    "release_target": {
      "type": "string",
      "enum": ["ios", "android"]
    },
    "provider_kind": {
      "type": "string",
      "enum": ["mock_v1", "appstoreconnect_v1", "googleplay_v1"]
    },
    "permission_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z][a-z0-9._-]*$"
    },
    "telemetry_class": {
      "type": "string",
      "enum": [
        "app.lifecycle",
        "app.http",
        "runtime.error",
        "bridge.timing",
        "reducer.timing",
        "policy.violation",
        "host.webview_crash"
      ]
    },
    "blob_store_capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "max_total_bytes", "max_item_bytes"],
      "properties": {
        "enabled": { "type": "boolean" },
        "max_total_bytes": { "type": "integer", "minimum": 1, "maximum": 1073741824 },
        "max_item_bytes": { "type": "integer", "minimum": 1, "maximum": 268435456 }
      }
    },
    "native_capability_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "camera_photo",
        "files_pick",
        "blob_store",
        "location_foreground",
        "notifications_local",
        "notifications_push"
      ],
      "properties": {
        "camera_photo": { "type": "boolean" },
        "files_pick": { "type": "boolean" },
        "blob_store": { "$ref": "#/$defs/blob_store_capability" },
        "location_foreground": { "type": "boolean" },
        "notifications_local": { "type": "boolean" },
        "notifications_push": { "type": "boolean" }
      }
    },
    "native_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_kind",
        "provider_kind",
        "package_manifest_sha256",
        "capabilities",
        "permission_declarations",
        "telemetry_classes"
      ],
      "properties": {
        "target_kind": { "$ref": "#/$defs/release_target" },
        "provider_kind": { "$ref": "#/$defs/provider_kind" },
        "package_manifest_sha256": { "$ref": "#/$defs/sha256" },
        "capabilities": { "$ref": "#/$defs/native_capability_summary" },
        "permission_declarations": {
          "type": "array",
          "minItems": 0,
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/permission_id" }
        },
        "telemetry_classes": {
          "type": "array",
          "minItems": 0,
          "maxItems": 16,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/telemetry_class" }
        }
      }
    },
    "readiness_issue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[A-Z][A-Z0-9_-]*$"
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "field": {
          "type": "string",
          "maxLength": 256
        }
      }
    },
    "release_readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "warnings", "errors"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ok", "warn", "blocked"]
        },
        "warnings": {
          "type": "array",
          "maxItems": 128,
          "items": { "$ref": "#/$defs/readiness_issue" },
          "default": []
        },
        "errors": {
          "type": "array",
          "maxItems": 128,
          "items": { "$ref": "#/$defs/readiness_issue" },
          "default": []
        }
      }
    },
    "native_health_rollup": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "native_runtime_error_count",
        "native_policy_violation_count",
        "native_bridge_timeout_count",
        "native_host_crash_count",
        "native_permission_blocked_count",
        "last_native_event_unix_ms"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["unknown", "healthy", "degraded", "failed"]
        },
        "native_runtime_error_count": { "type": "integer", "minimum": 0 },
        "native_policy_violation_count": { "type": "integer", "minimum": 0 },
        "native_bridge_timeout_count": { "type": "integer", "minimum": 0 },
        "native_host_crash_count": { "type": "integer", "minimum": 0 },
        "native_permission_blocked_count": { "type": "integer", "minimum": 0 },
        "last_native_event_unix_ms": {
          "oneOf": [{ "$ref": "#/$defs/unix_ms" }, { "type": "null" }],
          "default": null
        }
      }
    },
    "regression_status": {
      "type": "string",
      "enum": ["not_requested", "requested", "generated", "failed", "unavailable"]
    },
    "exec_status": {
      "type": "string",
      "enum": ["planned", "started", "completed", "failed", "aborted"]
    },
    "plan_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "digest"],
      "properties": {
        "kind": { "const": "lp.device.release.plan@0.2.0" },
        "digest": { "$ref": "#/$defs/digest_ref" }
      }
    },
    "exec_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["idx", "status", "started_unix_ms", "ended_unix_ms"],
      "properties": {
        "idx": { "type": "integer", "minimum": 0 },
        "name": { "type": "string", "maxLength": 128 },
        "kind": { "type": "string", "maxLength": 128 },
        "status": { "type": "string", "enum": ["ok", "error", "skipped", "running"] },
        "started_unix_ms": { "$ref": "#/$defs/unix_ms" },
        "ended_unix_ms": {
          "oneOf": [{ "$ref": "#/$defs/unix_ms" }, { "type": "null" }],
          "default": null
        },
        "attempt": { "type": "integer", "minimum": 1, "default": 1 },
        "latest_rollout_percent": {
          "oneOf": [
            { "type": "integer", "minimum": 0, "maximum": 100 },
            { "type": "null" }
          ],
          "default": null
        },
        "store_release_id": {
          "oneOf": [
            { "type": "string", "minLength": 1, "maxLength": 256 },
            { "type": "null" }
          ],
          "default": null
        },
        "decisions": {
          "type": "array",
          "maxItems": 128,
          "items": { "$ref": "#/$defs/id" },
          "default": []
        },
        "evidence": {
          "type": "array",
          "maxItems": 256,
          "items": { "$ref": "#/$defs/artifact_ref" },
          "default": []
        }
      }
    }
  }
}
