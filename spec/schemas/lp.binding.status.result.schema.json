{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.binding.status.result.schema.json",
  "title": "lp.binding.status.result@0.1.0",
  "description": "Binding inventory or detail result used by UI, CLI, MCP, and hosted target checks.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "view",
    "items",
    "generated_unix_ms"
  ],
  "properties": {
    "schema_version": {
      "const": "lp.binding.status.result@0.1.0"
    },
    "view": {
      "enum": [
        "list",
        "detail"
      ]
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "binding_id",
          "name",
          "kind",
          "status"
        ],
        "properties": {
          "binding_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "kind": {
            "type": "string",
            "enum": [
              "postgres",
              "mysql",
              "sqlite",
              "redis",
              "kafka",
              "amqp",
              "s3",
              "secret",
              "otlp"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "ready",
              "error",
              "disabled"
            ]
          },
          "provider_kind": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "configured": {
            "type": "boolean",
            "default": false
          },
          "target_id": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "reason_code": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "last_checked_unix_ms": {
            "oneOf": [
              {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "probe_result_id": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "message": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1,
                "maxLength": 512
              },
              {
                "type": "null"
              }
            ],
            "default": null
          }
        }
      }
    },
    "generated_unix_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    }
  }
}
