{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.secret.list.result.schema.json",
  "title": "lp.secret.list.result@0.1.0",
  "description": "Result payload for hosted secret inventory surfaces. Secret values are never included.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "view",
    "generated_unix_ms",
    "org_id",
    "project_id",
    "environment_id",
    "items"
  ],
  "properties": {
    "schema_version": {
      "const": "lp.secret.list.result@0.1.0"
    },
    "view": {
      "const": "list"
    },
    "generated_unix_ms": {
      "$ref": "#/$defs/unix_ms"
    },
    "org_id": {
      "$ref": "#/$defs/id"
    },
    "project_id": {
      "$ref": "#/$defs/id"
    },
    "environment_id": {
      "$ref": "#/$defs/id"
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/item"
      },
      "maxItems": 4096,
      "default": []
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "unix_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991,
      "description": "Unix timestamp in milliseconds (non-negative, JS-safe integer)."
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "value_sha256",
        "created_unix_ms",
        "updated_unix_ms"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "value_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "created_unix_ms": {
          "$ref": "#/$defs/unix_ms"
        },
        "updated_unix_ms": {
          "$ref": "#/$defs/unix_ms"
        }
      }
    }
  }
}
