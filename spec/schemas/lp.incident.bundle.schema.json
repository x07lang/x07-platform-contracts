{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.incident.bundle.schema.json",
  "title": "lp.incident.bundle@0.2.0",
  "description": "Portable bundle of incident evidence captured by the platform, with optional native incident context and release linkage.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "incident_id", "created_unix_ms", "app_id", "environment", "window", "refs"],
  "properties": {
    "schema_version": { "const": "lp.incident.bundle@0.2.0" },
    "incident_id": { "$ref": "#/$defs/id" },
    "created_unix_ms": { "$ref": "#/$defs/unix_ms" },
    "app_id": { "$ref": "#/$defs/id" },
    "environment": { "$ref": "#/$defs/environment" },
    "window": { "$ref": "#/$defs/window" },
    "deploy_execution": {
      "type": ["object", "null"],
      "default": null,
      "additionalProperties": false,
      "required": ["exec_id"],
      "properties": { "exec_id": { "$ref": "#/$defs/id" } }
    },
    "release_plan_id": {
      "oneOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }],
      "default": null
    },
    "release_exec_id": {
      "oneOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }],
      "default": null
    },
    "native_context": {
      "oneOf": [{ "$ref": "#/$defs/native_context" }, { "type": "null" }],
      "default": null
    },
    "request": { "oneOf": [{ "$ref": "#/$defs/req_ref" }, { "type": "null" }], "default": null },
    "response": { "oneOf": [{ "$ref": "#/$defs/resp_ref" }, { "type": "null" }], "default": null },
    "trace": { "oneOf": [{ "$ref": "#/$defs/trace_ref" }, { "type": "null" }], "default": null },
    "diag_codes": { "type": "array", "maxItems": 256, "items": { "$ref": "#/$defs/diag_code" }, "default": [] },
    "refs": { "type": "array", "maxItems": 2048, "items": { "$ref": "#/$defs/artifact_ref" }, "default": [] },
    "notes": { "type": "string", "maxLength": 16384 },
    "meta": { "type": "object", "additionalProperties": true, "default": {} }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "bytes_len": { "type": "integer", "minimum": 0 },
    "unix_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991,
      "description": "Unix timestamp in milliseconds (non-negative, JS-safe integer)."
    },
    "schema_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*@[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "digest_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256", "bytes_len"],
      "properties": {
        "sha256": { "$ref": "#/$defs/sha256" },
        "bytes_len": { "$ref": "#/$defs/bytes_len" }
      }
    },
    "artifact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["digest"],
      "properties": {
        "kind": { "$ref": "#/$defs/schema_id" },
        "digest": { "$ref": "#/$defs/digest_ref" },
        "label": { "type": "string", "maxLength": 256 }
      }
    },
    "env_name": { "type": "string", "minLength": 1, "maxLength": 64, "pattern": "^[a-z][a-z0-9_-]{0,63}$" },
    "environment": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": { "kind": { "type": "string", "enum": ["dev", "staging", "prod"] } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name"],
          "properties": { "kind": { "const": "custom" }, "name": { "$ref": "#/$defs/env_name" } }
        }
      ]
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_unix_ms", "end_unix_ms"],
      "properties": { "start_unix_ms": { "$ref": "#/$defs/unix_ms" }, "end_unix_ms": { "$ref": "#/$defs/unix_ms" } }
    },
    "diag_code": { "type": "string", "minLength": 1, "maxLength": 64, "pattern": "^[A-Z][A-Z0-9_-]*$" },
    "host_target_kind": {
      "type": "string",
      "enum": ["desktop", "ios", "android"]
    },
    "provider_kind": {
      "type": "string",
      "enum": ["mock_v1", "appstoreconnect_v1", "googleplay_v1"]
    },
    "permission_state": {
      "type": "string",
      "enum": ["granted", "denied", "prompt", "restricted", "unsupported"]
    },
    "blob_store_capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "max_total_bytes", "max_item_bytes"],
      "properties": {
        "enabled": { "type": "boolean" },
        "max_total_bytes": { "type": "integer", "minimum": 1, "maximum": 1073741824 },
        "max_item_bytes": { "type": "integer", "minimum": 1, "maximum": 268435456 }
      }
    },
    "capabilities_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "camera_photo",
        "files_pick",
        "blob_store",
        "location_foreground",
        "notifications_local",
        "notifications_push"
      ],
      "properties": {
        "camera_photo": { "type": "boolean" },
        "files_pick": { "type": "boolean" },
        "blob_store": { "$ref": "#/$defs/blob_store_capability" },
        "location_foreground": { "type": "boolean" },
        "notifications_local": { "type": "boolean" },
        "notifications_push": { "type": "boolean" }
      }
    },
    "permission_state_snapshot": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64,
        "pattern": "^[a-z][a-z0-9._-]*$"
      },
      "additionalProperties": { "$ref": "#/$defs/permission_state" },
      "maxProperties": 32,
      "default": {}
    },
    "breadcrumb": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ord", "event_class", "op", "status"],
      "properties": {
        "ord": { "type": "integer", "minimum": 0 },
        "event_class": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z][a-z0-9._-]*$"
        },
        "op": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-z][a-z0-9._-]*$"
        },
        "status": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z][a-z0-9._-]*$"
        },
        "request_id": {
          "oneOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }],
          "default": null
        },
        "unix_ms": {
          "oneOf": [{ "$ref": "#/$defs/unix_ms" }, { "type": "null" }],
          "default": null
        },
        "duration_ms": {
          "oneOf": [{ "type": "integer", "minimum": 0, "maximum": 3600000 }, { "type": "null" }],
          "default": null
        },
        "permission": {
          "type": "string",
          "maxLength": 64
        },
        "message": {
          "type": "string",
          "maxLength": 512
        }
      }
    },
    "native_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "platform",
        "capabilities_summary",
        "permission_state_snapshot",
        "lifecycle_state",
        "connectivity_state",
        "breadcrumbs"
      ],
      "properties": {
        "kind": { "const": "device_native" },
        "release_plan_id": {
          "oneOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }],
          "default": null
        },
        "release_exec_id": {
          "oneOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }],
          "default": null
        },
        "provider_kind": {
          "oneOf": [{ "$ref": "#/$defs/provider_kind" }, { "type": "null" }],
          "default": null
        },
        "platform": { "$ref": "#/$defs/host_target_kind" },
        "package_manifest_sha256": {
          "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }],
          "default": null
        },
        "capabilities_summary": { "$ref": "#/$defs/capabilities_summary" },
        "permission_state_snapshot": { "$ref": "#/$defs/permission_state_snapshot" },
        "lifecycle_state": {
          "type": "string",
          "enum": ["foreground", "background", "resume", "unknown"]
        },
        "connectivity_state": {
          "type": "string",
          "enum": ["online", "offline", "unknown"]
        },
        "breadcrumbs": {
          "type": "array",
          "maxItems": 128,
          "items": { "$ref": "#/$defs/breadcrumb" },
          "default": []
        }
      }
    },
    "req_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "digest"],
      "properties": { "kind": { "const": "x07.http.request.envelope@0.1.0" }, "digest": { "$ref": "#/$defs/digest_ref" } }
    },
    "resp_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "digest"],
      "properties": { "kind": { "const": "x07.http.response.envelope@0.1.0" }, "digest": { "$ref": "#/$defs/digest_ref" } }
    },
    "trace_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "digest"],
      "properties": { "kind": { "const": "x07.app.trace@0.1.0" }, "digest": { "$ref": "#/$defs/digest_ref" } }
    }
  }
}
