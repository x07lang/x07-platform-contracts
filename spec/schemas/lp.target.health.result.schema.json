{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.target.health.result.schema.json",
  "title": "lp.target.health.result@0.1.0",
  "description": "Provider-neutral target health summary and check results.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "target_id",
    "name",
    "kind",
    "status",
    "reachable",
    "checks",
    "observed_unix_ms"
  ],
  "properties": {
    "schema_version": {
      "const": "lp.target.health.result@0.1.0"
    },
    "target_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "kind": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "status": {
      "type": "string",
      "enum": [
        "unknown",
        "pending",
        "healthy",
        "degraded",
        "failed",
        "disabled"
      ]
    },
    "reachable": {
      "type": "boolean"
    },
    "provider_kind": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "capabilities_digest": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/check"
      },
      "default": []
    },
    "observed_unix_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "status",
        "observed_unix_ms"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "ready",
            "warning",
            "error",
            "disabled"
          ]
        },
        "message": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 1024
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "observed_unix_ms": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      }
    }
  }
}
