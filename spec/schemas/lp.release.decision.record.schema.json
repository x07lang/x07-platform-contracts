{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.release.decision.record.schema.json",
  "title": "lp.release.decision.record@0.1.0",
  "description": "Decision record emitted by human approval or automated policy evaluation for releases.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision_id",
    "release_id",
    "decision_kind",
    "actor_kind",
    "created_unix_ms"
  ],
  "properties": {
    "schema_version": {
      "const": "lp.release.decision.record@0.1.0"
    },
    "decision_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "release_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "decision_kind": {
      "type": "string",
      "enum": [
        "approve",
        "reject",
        "rollback",
        "promote",
        "abort",
        "canary_shift"
      ]
    },
    "actor_kind": {
      "type": "string",
      "enum": [
        "human",
        "service-account",
        "policy-engine"
      ]
    },
    "actor_id": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "reason_code": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "notes": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "created_unix_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    }
  }
}
