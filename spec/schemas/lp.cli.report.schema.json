{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.cli.report.schema.json",
  "title": "lp.cli.report@0.1.0",
  "description": "Stable report envelope for x07-platform CLI commands and MCP tools.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "command", "ok", "exit_code", "diagnostics", "result"],
  "properties": {
    "schema_version": { "const": "lp.cli.report@0.1.0" },
    "command": { "type": "string", "minLength": 1, "maxLength": 256 },
    "ok": { "type": "boolean" },
    "exit_code": { "type": "integer", "minimum": 0 },
    "diagnostics": { "type": "array", "items": { "$ref": "#/$defs/diagnostic" }, "default": [] },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "version", "run_id"],
      "properties": {
        "tool": { "const": "x07lp" },
        "version": { "type": "string", "minLength": 1, "maxLength": 64 },
        "run_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "artifacts_written": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifact_ref" },
          "default": []
        }
      }
    },
    "result": { "type": "object" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "artifact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algo", "sha256", "bytes_len", "media_type"],
      "properties": {
        "algo": { "const": "sha256" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "bytes_len": { "type": "integer", "minimum": 0 },
        "media_type": { "type": "string", "minLength": 1, "maxLength": 256 },
        "logical_name": { "type": "string", "maxLength": 256 },
        "store_uri": { "type": "string", "maxLength": 2048 }
      }
    },
    "severity": { "type": "string", "enum": ["error", "warning", "info", "hint"] },
    "stage": {
      "type": "string",
      "enum": ["parse", "lint", "rewrite", "type", "lower", "codegen", "link", "run"]
    },
    "json_pointer": {
      "type": "string",
      "minLength": 0,
      "maxLength": 2048,
      "description": "JSON Pointer (RFC 6901). Empty string means the whole document."
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["line", "col"],
      "properties": {
        "line": { "type": "integer", "minimum": 1 },
        "col": { "type": "integer", "minimum": 1 },
        "offset": { "type": "integer", "minimum": 0 }
      }
    },
    "span": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "file": { "type": "string" },
        "start": { "$ref": "#/$defs/position" },
        "end": { "$ref": "#/$defs/position" }
      }
    },
    "loc_x07ast": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "ptr"],
      "properties": { "kind": { "const": "x07ast" }, "ptr": { "$ref": "#/$defs/json_pointer" } }
    },
    "loc_text": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "span"],
      "properties": {
        "kind": { "const": "text" },
        "span": { "$ref": "#/$defs/span" },
        "snippet": { "type": "string", "maxLength": 2048 }
      }
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "primary"],
      "properties": {
        "file": { "type": "string", "maxLength": 1024 },
        "primary": {
          "oneOf": [
            { "$ref": "#/$defs/loc_x07ast" },
            { "$ref": "#/$defs/loc_text" }
          ]
        },
        "note": { "type": "string", "maxLength": 512 }
      }
    },
    "quickfix": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "enum": ["patchset", "json_patch", "message"] },
        "patchset": { "type": "object" },
        "json_patch": { "type": "array" },
        "message": { "type": "string", "maxLength": 2048 }
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "stage", "message"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[A-Z][A-Z0-9_-]*$"
        },
        "severity": { "$ref": "#/$defs/severity" },
        "stage": { "$ref": "#/$defs/stage" },
        "message": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "loc": { "$ref": "#/$defs/location" },
        "notes": { "type": "array", "items": { "type": "string", "maxLength": 2048 }, "default": [] },
        "related": { "type": "array", "items": { "$ref": "#/$defs/location" }, "default": [] },
        "data": { "type": "object", "additionalProperties": true, "default": {} },
        "quickfix": { "$ref": "#/$defs/quickfix" }
      }
    }
  }
}
