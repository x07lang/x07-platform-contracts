{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.device.release.plan.schema.json",
  "title": "lp.device.release.plan@0.2.0",
  "description": "Deterministic rollout plan for releasing a sealed device package through a single store/provider target, including the normalized native summary frozen at release creation time.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_id",
    "created_unix_ms",
    "provider_profile",
    "target",
    "app",
    "package",
    "native_summary",
    "release_readiness",
    "strategy",
    "steps"
  ],
  "properties": {
    "schema_version": { "const": "lp.device.release.plan@0.2.0" },
    "plan_id": { "$ref": "#/$defs/id" },
    "created_unix_ms": { "$ref": "#/$defs/unix_ms" },
    "provider_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "digest"],
      "properties": {
        "kind": { "const": "lp.device.store.provider.profile@0.1.0" },
        "digest": { "$ref": "#/$defs/digest_ref" },
        "provider_id": { "$ref": "#/$defs/id" }
      }
    },
    "target": { "$ref": "#/$defs/release_target" },
    "app": {
      "type": "object",
      "additionalProperties": false,
      "required": ["app_id", "track_or_lane", "version", "build"],
      "properties": {
        "app_id": { "$ref": "#/$defs/id" },
        "track_or_lane": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "build": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      }
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "digest"],
      "properties": {
        "kind": { "const": "x07.device.package.manifest@0.1.0" },
        "digest": { "$ref": "#/$defs/digest_ref" },
        "label": { "type": "string", "maxLength": 256 }
      }
    },
    "native_summary": { "$ref": "#/$defs/native_summary" },
    "release_readiness": { "$ref": "#/$defs/release_readiness" },
    "strategy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_auto_steps", "max_total_wait_seconds", "on_provider_error"],
      "properties": {
        "max_auto_steps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4096
        },
        "max_total_wait_seconds": {
          "type": "integer",
          "minimum": 0,
          "maximum": 31536000
        },
        "on_provider_error": {
          "type": "string",
          "enum": ["fail", "pause", "require_human"]
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4096,
      "items": { "$ref": "#/$defs/step" }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "digest_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256", "bytes_len"],
      "properties": {
        "sha256": { "$ref": "#/$defs/sha256" },
        "bytes_len": { "type": "integer", "minimum": 0 }
      }
    },
    "unix_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991,
      "description": "Unix timestamp in milliseconds (non-negative, JS-safe integer)."
    },
    "release_target": {
      "type": "string",
      "enum": ["ios", "android"]
    },
    "provider_kind": {
      "type": "string",
      "enum": ["mock_v1", "appstoreconnect_v1", "googleplay_v1"]
    },
    "permission_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z][a-z0-9._-]*$"
    },
    "telemetry_class": {
      "type": "string",
      "enum": [
        "app.lifecycle",
        "app.http",
        "runtime.error",
        "bridge.timing",
        "reducer.timing",
        "policy.violation",
        "host.webview_crash"
      ]
    },
    "blob_store_capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "max_total_bytes", "max_item_bytes"],
      "properties": {
        "enabled": { "type": "boolean" },
        "max_total_bytes": { "type": "integer", "minimum": 1, "maximum": 1073741824 },
        "max_item_bytes": { "type": "integer", "minimum": 1, "maximum": 268435456 }
      }
    },
    "native_capability_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "camera_photo",
        "files_pick",
        "blob_store",
        "location_foreground",
        "notifications_local",
        "notifications_push"
      ],
      "properties": {
        "camera_photo": { "type": "boolean" },
        "files_pick": { "type": "boolean" },
        "blob_store": { "$ref": "#/$defs/blob_store_capability" },
        "location_foreground": { "type": "boolean" },
        "notifications_local": { "type": "boolean" },
        "notifications_push": { "type": "boolean" }
      }
    },
    "native_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_kind",
        "provider_kind",
        "package_manifest_sha256",
        "capabilities",
        "permission_declarations",
        "telemetry_classes"
      ],
      "properties": {
        "target_kind": { "$ref": "#/$defs/release_target" },
        "provider_kind": { "$ref": "#/$defs/provider_kind" },
        "package_manifest_sha256": { "$ref": "#/$defs/sha256" },
        "capabilities": { "$ref": "#/$defs/native_capability_summary" },
        "permission_declarations": {
          "type": "array",
          "minItems": 0,
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/permission_id" }
        },
        "telemetry_classes": {
          "type": "array",
          "minItems": 0,
          "maxItems": 16,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/telemetry_class" }
        }
      }
    },
    "readiness_issue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[A-Z][A-Z0-9_-]*$"
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "field": {
          "type": "string",
          "maxLength": 256
        }
      }
    },
    "release_readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "warnings", "errors"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ok", "warn", "blocked"]
        },
        "warnings": {
          "type": "array",
          "maxItems": 128,
          "items": { "$ref": "#/$defs/readiness_issue" },
          "default": []
        },
        "errors": {
          "type": "array",
          "maxItems": 128,
          "items": { "$ref": "#/$defs/readiness_issue" },
          "default": []
        }
      }
    },
    "step_on_fail": {
      "type": "string",
      "enum": ["fail", "pause", "require_human", "release.pause", "release.halt"]
    },
    "metrics_eval_on_fail": {
      "type": "string",
      "enum": ["release.pause", "release.halt", "require_human"]
    },
    "slo_profile_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "digest"],
      "properties": {
        "kind": { "const": "x07.slo.profile@0.1.0" },
        "digest": { "$ref": "#/$defs/digest_ref" },
        "label": { "type": "string", "maxLength": 256 }
      }
    },
    "step_release_start": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "op"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "op": { "const": "release.start" },
        "on_fail": { "$ref": "#/$defs/step_on_fail" }
      }
    },
    "step_rollout_set_percent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "op", "percent"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "op": { "const": "rollout.set_percent" },
        "percent": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "on_fail": { "$ref": "#/$defs/step_on_fail" }
      }
    },
    "step_release_pause": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "op"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "op": { "const": "release.pause" },
        "on_fail": { "$ref": "#/$defs/step_on_fail" }
      }
    },
    "step_release_resume": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "op"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "op": { "const": "release.resume" },
        "on_fail": { "$ref": "#/$defs/step_on_fail" }
      }
    },
    "step_metrics_eval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "op", "window_seconds", "thresholds", "on_fail"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "op": { "const": "metrics.eval" },
        "window_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 31536000
        },
        "thresholds": { "$ref": "#/$defs/slo_profile_ref" },
        "on_fail": { "$ref": "#/$defs/metrics_eval_on_fail" }
      }
    },
    "step_release_complete": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "op"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "op": { "const": "release.complete" },
        "on_fail": { "$ref": "#/$defs/step_on_fail" }
      }
    },
    "step_rollback_previous": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "op"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "op": { "const": "rollback.previous" },
        "on_fail": { "$ref": "#/$defs/step_on_fail" }
      }
    },
    "step": {
      "oneOf": [
        { "$ref": "#/$defs/step_release_start" },
        { "$ref": "#/$defs/step_rollout_set_percent" },
        { "$ref": "#/$defs/step_release_pause" },
        { "$ref": "#/$defs/step_release_resume" },
        { "$ref": "#/$defs/step_metrics_eval" },
        { "$ref": "#/$defs/step_release_complete" },
        { "$ref": "#/$defs/step_rollback_previous" }
      ]
    }
  }
}
