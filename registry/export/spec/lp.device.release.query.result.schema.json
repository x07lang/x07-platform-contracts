{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.device.release.query.result.schema.json",
  "title": "lp.device.release.query.result@0.1.0",
  "description": "Result object for x07lp device release query and the corresponding MCP/UI surfaces.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "view",
    "exec_id",
    "plan_id",
    "provider_kind",
    "target"
  ],
  "properties": {
    "schema_version": {
      "const": "lp.device.release.query.result@0.1.0"
    },
    "view": {
      "type": "string",
      "enum": ["summary", "timeline", "decisions", "full"]
    },
    "exec_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "plan_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "provider_kind": {
      "type": "string",
      "enum": ["mock_v1", "appstoreconnect_v1", "googleplay_v1"]
    },
    "distribution_lane": {
      "type": "string",
      "enum": ["beta", "production"]
    },
    "target": {
      "type": "string",
      "enum": ["ios", "android"]
    },
    "status": {
      "type": "string",
      "enum": ["planned", "started", "completed", "failed", "aborted"]
    },
    "created_unix_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991,
      "description": "Unix timestamp in milliseconds (non-negative, JS-safe integer)."
    },
    "updated_unix_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991,
      "description": "Unix timestamp in milliseconds (non-negative, JS-safe integer)."
    },
    "app": {
      "type": "object",
      "additionalProperties": false,
      "required": ["app_id", "track_or_lane", "version", "build"],
      "properties": {
        "app_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "track_or_lane": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "build": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      }
    },
    "current_state": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "available",
        "in_progress",
        "paused",
        "halted",
        "completed",
        "rolled_back"
      ]
    },
    "current_rollout_percent": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "latest_decision_id": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "latest_signed_control_decision_id": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "signature_status": {
      "type": "string",
      "enum": ["valid", "missing", "invalid", "not_applicable"]
    },
    "decision_count": {
      "type": "integer",
      "minimum": 0
    },
    "provider_release_id": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "execution": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "digest"],
          "properties": {
            "kind": { "const": "lp.device.release.execution@0.1.0" },
            "digest": {
              "type": "object",
              "additionalProperties": false,
              "required": ["sha256", "bytes_len"],
              "properties": {
                "sha256": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{64}$"
                },
                "bytes_len": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          }
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "decision_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128,
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
      },
      "default": []
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      },
      "default": []
    },
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    },
    "index": {
      "type": "object",
      "additionalProperties": false,
      "required": ["used", "rebuilt", "db_path"],
      "properties": {
        "used": {
          "type": "boolean"
        },
        "rebuilt": {
          "type": "boolean"
        },
        "db_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        }
      }
    }
  }
}
