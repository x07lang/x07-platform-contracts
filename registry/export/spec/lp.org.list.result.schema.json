{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.org.list.result.schema.json",
  "title": "lp.org.list.result@0.1.0",
  "description": "Result payload for hosted organization listing and selection surfaces.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "view", "items", "generated_unix_ms"],
  "properties": {
    "schema_version": { "const": "lp.org.list.result@0.1.0" },
    "view": { "const": "list" },
    "generated_unix_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/item" },
      "maxItems": 4096,
      "default": []
    }
  },
  "$defs": {
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "org_id",
        "org_slug",
        "display_name",
        "role",
        "selected",
        "created_unix_ms",
        "updated_unix_ms"
      ],
      "properties": {
        "org_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "org_slug": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z][a-z0-9_-]{0,63}$"
        },
        "display_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "role": {
          "type": "string",
          "enum": ["owner", "developer", "viewer"]
        },
        "selected": { "type": "boolean" },
        "created_unix_ms": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "updated_unix_ms": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      }
    }
  }
}
