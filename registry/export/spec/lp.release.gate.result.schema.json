{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.release.gate.result.schema.json",
  "title": "lp.release.gate.result@0.1.0",
  "description": "Gate decision result for deploy or rollback release actions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "release_id",
    "target_id",
    "action",
    "decision",
    "generated_unix_ms"
  ],
  "properties": {
    "schema_version": {
      "const": "lp.release.gate.result@0.1.0"
    },
    "release_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "target_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "action": {
      "type": "string",
      "enum": [
        "deploy",
        "rollback"
      ]
    },
    "decision": {
      "type": "string",
      "enum": [
        "allow",
        "deny",
        "hold"
      ]
    },
    "decision_id": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128
      },
      "default": []
    },
    "message": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "deployment_id": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "expires_unix_ms": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "generated_unix_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    }
  }
}
