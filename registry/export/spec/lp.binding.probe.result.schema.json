{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.binding.probe.result.schema.json",
  "title": "lp.binding.probe.result@0.1.0",
  "description": "Provider-neutral binding probe result that distinguishes configuration from real connectivity.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "binding_id",
    "name",
    "kind",
    "status",
    "checks",
    "observed_unix_ms"
  ],
  "properties": {
    "schema_version": {
      "const": "lp.binding.probe.result@0.1.0"
    },
    "binding_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "kind": {
      "type": "string",
      "enum": [
        "postgres",
        "mysql",
        "sqlite",
        "redis",
        "kafka",
        "amqp",
        "s3",
        "secret",
        "otlp"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "ready",
        "error",
        "disabled"
      ]
    },
    "configured": {
      "type": "boolean",
      "default": false
    },
    "provider_kind": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "target_id": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/check"
      },
      "default": []
    },
    "observed_unix_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "status",
        "observed_unix_ms"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "ready",
            "warning",
            "error",
            "disabled"
          ]
        },
        "message": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 1024
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "observed_unix_ms": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      }
    }
  }
}
