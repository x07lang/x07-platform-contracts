{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.control.action.result.schema.json",
  "title": "lp.control.action.result@0.1.0",
  "description": "Result object for manual control-plane actions in Phase C: deploy pause/rerun/stop/rollback and app/platform kill or clear-kill operations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "action_id",
    "kind",
    "scope",
    "ok",
    "approval_state",
    "created_unix_ms",
    "target",
    "affected_executions",
    "decision"
  ],
  "properties": {
    "schema_version": {
      "const": "lp.control.action.result@0.1.0"
    },
    "action_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "deploy.pause.manual",
        "deploy.rerun.manual",
        "deploy.stop.manual",
        "deploy.rollback.manual",
        "app.kill",
        "app.unkill",
        "platform.kill",
        "platform.unkill"
      ]
    },
    "scope": {
      "type": "string",
      "enum": [
        "deployment",
        "app",
        "platform"
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "approval_state": {
      "type": "string",
      "enum": [
        "not_required",
        "required",
        "granted",
        "denied"
      ]
    },
    "created_unix_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991,
      "description": "Unix timestamp in milliseconds (non-negative, JS-safe integer)."
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "deployment_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "app_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "environment": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z][a-z0-9_-]{0,63}$"
        }
      },
      "default": {}
    },
    "reason": {
      "type": "string",
      "maxLength": 4096
    },
    "affected_executions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128,
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
      },
      "default": []
    },
    "new_execution_id": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "state_before": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "control_state",
            "kill_scope",
            "kill_latched"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "planned",
                "started",
                "completed",
                "failed",
                "aborted"
              ]
            },
            "control_state": {
              "type": "string",
              "enum": [
                "active",
                "paused",
                "stopping",
                "killed",
                "terminal"
              ]
            },
            "kill_scope": {
              "type": "string",
              "enum": [
                "none",
                "app",
                "platform"
              ]
            },
            "kill_latched": {
              "type": "boolean"
            }
          }
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "state_after": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "control_state",
            "kill_scope",
            "kill_latched"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "planned",
                "started",
                "completed",
                "failed",
                "aborted"
              ]
            },
            "control_state": {
              "type": "string",
              "enum": [
                "active",
                "paused",
                "stopping",
                "killed",
                "terminal"
              ]
            },
            "kill_scope": {
              "type": "string",
              "enum": [
                "none",
                "app",
                "platform"
              ]
            },
            "kill_latched": {
              "type": "boolean"
            }
          }
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_id",
        "signature_status"
      ],
      "properties": {
        "decision_id": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "signature_status": {
          "type": "string",
          "enum": [
            "valid",
            "missing",
            "invalid",
            "not_applicable"
          ]
        },
        "record": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "digest"
              ],
              "properties": {
                "kind": {
                  "type": "string",
                  "minLength": 3,
                  "maxLength": 128,
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*@[0-9]+\\.[0-9]+\\.[0-9]+$"
                },
                "digest": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "sha256",
                    "bytes_len"
                  ],
                  "properties": {
                    "sha256": {
                      "type": "string",
                      "pattern": "^[0-9a-f]{64}$"
                    },
                    "bytes_len": {
                      "type": "integer",
                      "minimum": 0
                    }
                  }
                },
                "label": {
                  "type": "string",
                  "maxLength": 256
                },
                "store_uri": {
                  "type": "string",
                  "maxLength": 2048
                },
                "media_type": {
                  "type": "string",
                  "maxLength": 256
                },
                "logical_name": {
                  "type": "string",
                  "maxLength": 256
                }
              }
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      }
    },
    "message": {
      "type": "string",
      "maxLength": 2048
    }
  }
}
