{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.target.profile.schema.json",
  "title": "lp.target.profile@0.1.0",
  "description": "Creator-side target configuration for OSS remote x07-platform control planes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "name",
    "kind",
    "base_url",
    "api_version",
    "auth",
    "runtime_provider",
    "routing_provider"
  ],
  "properties": {
    "schema_version": {
      "const": "lp.target.profile@0.1.0"
    },
    "name": {
      "$ref": "#/$defs/id"
    },
    "kind": {
      "const": "oss_remote"
    },
    "base_url": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048
    },
    "api_version": {
      "const": "v1"
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "token_ref"
      ],
      "properties": {
        "kind": {
          "const": "static_bearer"
        },
        "token_ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048,
          "pattern": "^file://.+$"
        }
      }
    },
    "tls": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "system",
            "custom_bundle",
            "insecure_skip_verify"
          ]
        },
        "ca_bundle_path": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1,
          "maxLength": 2048,
          "default": null
        }
      }
    },
    "runtime_provider": {
      "type": "string",
      "enum": [
        "wasmcloud",
        "lp.impl.runtime.wasmcloud_v1"
      ]
    },
    "routing_provider": {
      "type": "string",
      "enum": [
        "edge_http_v1",
        "lp.impl.routing.edge_http_v1"
      ]
    },
    "telemetry_provider": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "otlp_http_v1",
        "lp.impl.telemetry.otlp_http_v1",
        null
      ],
      "default": null
    },
    "secrets_provider": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "server_store_v1",
        "lp.impl.secrets.server_store_v1",
        null
      ],
      "default": null
    },
    "component_registry": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "oci_v1",
        "lp.impl.component_registry.oci_v1",
        null
      ],
      "default": null
    },
    "oci_registry": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 512,
      "default": null
    },
    "lattice_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 128,
      "default": null
    },
    "default_namespace": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 128,
      "default": null
    },
    "default_env": {
      "oneOf": [
        {
          "$ref": "#/$defs/environment_key"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "telemetry_collector_hint": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 2048,
      "default": null
    },
    "expect_capabilities_digest": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^sha256:[0-9a-f]{64}$",
      "default": null
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "environment_key": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    }
  }
}
