{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.release.gate.request.schema.json",
  "title": "lp.release.gate.request@0.1.0",
  "description": "Gate handshake request between release-control surfaces and a runtime target.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "release_id",
    "workload_id",
    "target_id",
    "action",
    "submitted_unix_ms"
  ],
  "properties": {
    "schema_version": {
      "const": "lp.release.gate.request@0.1.0"
    },
    "release_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "workload_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "target_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "action": {
      "type": "string",
      "enum": [
        "deploy",
        "rollback"
      ]
    },
    "deployment_id": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "rollout_strategy": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "requested_by": {
      "$ref": "#/$defs/subject"
    },
    "evidence_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128
      },
      "default": []
    },
    "rollback_to_release_id": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "submitted_unix_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    }
  },
  "$defs": {
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subject_kind"
      ],
      "properties": {
        "subject_kind": {
          "type": "string",
          "enum": [
            "human",
            "service-account",
            "policy-engine"
          ]
        },
        "subject_id": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      }
    }
  }
}
