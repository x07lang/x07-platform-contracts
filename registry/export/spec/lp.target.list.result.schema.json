{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.target.list.result.schema.json",
  "title": "lp.target.list.result@0.1.0",
  "description": "Result payload for x07lp target ls and target inspect commands.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "items"
  ],
  "properties": {
    "schema_version": {
      "const": "lp.target.list.result@0.1.0"
    },
    "current_target": {
      "oneOf": [
        {
          "$ref": "#/$defs/id"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/item"
      },
      "default": []
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "unix_ms": {
      "type": "integer",
      "minimum": 0
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "kind",
        "base_url",
        "runtime_provider",
        "routing_provider",
        "active",
        "reachable",
        "last_checked_unix_ms"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/id"
        },
        "kind": {
          "const": "oss_remote"
        },
        "base_url": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        },
        "runtime_provider": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "routing_provider": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "active": {
          "type": "boolean"
        },
        "reachable": {
          "type": "boolean"
        },
        "last_checked_unix_ms": {
          "oneOf": [
            {
              "$ref": "#/$defs/unix_ms"
            },
            {
              "type": "null"
            }
          ]
        },
        "api_version": {
          "const": "v1"
        },
        "default_namespace": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1,
          "maxLength": 128,
          "default": null
        },
        "default_env": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1,
          "maxLength": 64,
          "default": null
        },
        "capabilities_digest": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^sha256:[0-9a-f]{64}$",
          "default": null
        }
      }
    }
  }
}
