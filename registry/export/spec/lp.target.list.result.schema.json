{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.target.list.result.schema.json",
  "title": "lp.target.list.result@0.1.0",
  "description": "Result payload for x07lp target ls.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "items"],
  "properties": {
    "schema_version": { "const": "lp.target.list.result@0.1.0" },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/item" },
      "maxItems": 4096,
      "default": []
    }
  },
  "$defs": {
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_id",
        "name",
        "kind",
        "base_url",
        "runtime_provider",
        "routing_provider",
        "active",
        "reachable",
        "last_checked_unix_ms"
      ],
      "properties": {
        "target_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "kind": { "type": "string", "minLength": 1, "maxLength": 64 },
        "base_url": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "runtime_provider": { "type": "string", "minLength": 1, "maxLength": 128 },
        "routing_provider": { "type": "string", "minLength": 1, "maxLength": 128 },
        "active": { "type": "boolean" },
        "reachable": { "type": "boolean" },
        "status": {
          "type": "string",
          "enum": [
            "unknown",
            "pending",
            "healthy",
            "degraded",
            "failed",
            "disabled"
          ]
        },
        "last_heartbeat_unix_ms": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "last_checked_unix_ms": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      }
    }
  }
}
