{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.app.list.result.schema.json",
  "title": "lp.app.list.result@0.1.0",
  "description": "Result object for x07lp app list and the corresponding UI/MCP app table surfaces.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "view",
    "index",
    "items",
    "generated_unix_ms"
  ],
  "properties": {
    "schema_version": {
      "const": "lp.app.list.result@0.1.0"
    },
    "view": {
      "const": "list"
    },
    "index": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "used",
        "rebuilt",
        "db_path"
      ],
      "properties": {
        "used": {
          "type": "boolean"
        },
        "rebuilt": {
          "type": "boolean"
        },
        "db_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        }
      }
    },
    "generated_unix_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991,
      "description": "Unix timestamp in milliseconds (non-negative, JS-safe integer)."
    },
    "filters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "app_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "environment": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z][a-z0-9_-]{0,63}$"
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        }
      },
      "default": {}
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "app_id",
          "environment",
          "latest_deployment_id",
          "deployment_status",
          "outcome",
          "public_listener",
          "current_weight_pct",
          "incident_count_total",
          "incident_count_open",
          "latest_incident_id",
          "latest_decision_id",
          "kill_state",
          "updated_unix_ms"
        ],
        "properties": {
          "app_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
          },
          "environment": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^[a-z][a-z0-9_-]{0,63}$"
          },
          "latest_deployment_id": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1,
                "maxLength": 128,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "deployment_status": {
            "oneOf": [
              {
                "type": "string",
                "enum": [
                  "planned",
                  "started",
                  "completed",
                  "failed",
                  "aborted"
                ]
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "control_state": {
            "oneOf": [
              {
                "type": "string",
                "enum": [
                  "active",
                  "paused",
                  "stopping",
                  "killed",
                  "terminal"
                ]
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "outcome": {
            "oneOf": [
              {
                "type": "string",
                "enum": [
                  "unknown",
                  "promoted",
                  "rolled_back",
                  "aborted",
                  "failed"
                ]
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "public_listener": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1,
                "maxLength": 512
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "current_weight_pct": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "incident_count_total": {
            "type": "integer",
            "minimum": 0
          },
          "incident_count_open": {
            "type": "integer",
            "minimum": 0
          },
          "latest_incident_id": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1,
                "maxLength": 128,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "latest_decision_id": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1,
                "maxLength": 128,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "kill_state": {
            "type": "string",
            "enum": [
              "none",
              "app",
              "platform"
            ]
          },
          "updated_unix_ms": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991,
            "description": "Unix timestamp in milliseconds (non-negative, JS-safe integer)."
          }
        }
      },
      "default": []
    }
  }
}
