{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.change_request.schema.json",
  "title": "lp.change_request@0.1.0",
  "description": "Structured change/deploy request for x07-platform. No prose-only requests: acceptance checks and constraints are structured fields.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "change_id",
    "created_unix_ms",
    "target",
    "intent",
    "acceptance",
    "constraints"
  ],
  "properties": {
    "schema_version": { "const": "lp.change_request@0.1.0" },
    "change_id": { "$ref": "#/$defs/id" },
    "created_unix_ms": { "$ref": "#/$defs/unix_ms" },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["app_id", "environment"],
      "properties": {
        "app_id": { "$ref": "#/$defs/id" },
        "environment": { "$ref": "#/$defs/environment" }
      }
    },
    "intent": {
      "type": "string",
      "enum": ["deploy", "rollback", "stop", "replay", "validate_only"]
    },
    "acceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_checks", "policy_mode"],
      "properties": {
        "required_checks": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": { "$ref": "#/$defs/check_id" }
        },
        "policy_mode": { "type": "string", "enum": ["enforce", "warn"] }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allow_unsafe", "max_risk_tier"],
      "properties": {
        "allow_unsafe": { "type": "boolean", "default": false },
        "max_risk_tier": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "Upper bound on allowed risk for this change."
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo_url", "commit_sha"],
      "properties": {
        "repo_url": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "commit_sha": {
          "type": "string",
          "minLength": 7,
          "maxLength": 64,
          "pattern": "^[0-9a-fA-F]{7,64}$"
        },
        "pr_url": { "type": "string", "maxLength": 2048 }
      }
    },
    "requested_by": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": { "type": "string", "enum": ["human", "agent", "system"] },
        "id": { "type": "string", "minLength": 1, "maxLength": 256 },
        "display": { "type": "string", "maxLength": 256 }
      }
    },
    "labels": {
      "type": "array",
      "maxItems": 64,
      "items": { "type": "string", "minLength": 1, "maxLength": 64 },
      "default": []
    },
    "notes": { "type": "string", "maxLength": 16384 }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "unix_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991,
      "description": "Unix timestamp in milliseconds (non-negative, JS-safe integer)."
    },
    "env_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z][a-z0-9_-]{0,63}$",
      "description": "Custom environment identifier."
    },
    "environment": {
      "description": "Deployment environment selector.",
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": { "kind": { "type": "string", "enum": ["dev", "staging", "prod"] } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name"],
          "properties": { "kind": { "const": "custom" }, "name": { "$ref": "#/$defs/env_name" } }
        }
      ]
    },
    "check_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    }
  }
}
