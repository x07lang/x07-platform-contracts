{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.deploy.push.result.schema.json",
  "title": "lp.deploy.push.result@0.1.0",
  "description": "Result payload for the remote CAS probe/upload operation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "target",
    "artifact",
    "manifest_digest",
    "probed",
    "missing_count",
    "uploaded_count",
    "skipped_count",
    "uploaded",
    "skipped"
  ],
  "properties": {
    "schema_version": { "const": "lp.deploy.push.result@0.1.0" },
    "target": { "type": "string", "minLength": 1, "maxLength": 128 },
    "artifact": { "type": "string", "minLength": 1, "maxLength": 128 },
    "manifest_digest": { "$ref": "#/$defs/digest_ref" },
    "probed": { "type": "boolean" },
    "missing_count": { "type": "integer", "minimum": 0 },
    "uploaded_count": { "type": "integer", "minimum": 0 },
    "skipped_count": { "type": "integer", "minimum": 0 },
    "uploaded": {
      "type": "array",
      "items": { "$ref": "#/$defs/push_item" },
      "maxItems": 8192,
      "default": []
    },
    "skipped": {
      "type": "array",
      "items": { "$ref": "#/$defs/push_item" },
      "maxItems": 8192,
      "default": []
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "digest_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256", "bytes_len"],
      "properties": {
        "sha256": { "$ref": "#/$defs/sha256" },
        "bytes_len": { "type": "integer", "minimum": 0 }
      }
    },
    "push_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256", "bytes_len"],
      "properties": {
        "sha256": { "$ref": "#/$defs/sha256" },
        "bytes_len": { "type": "integer", "minimum": 0 },
        "logical_name": { "type": "string", "maxLength": 512 },
        "store_uri": { "type": "string", "maxLength": 2048 }
      }
    }
  }
}
