{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.incident.bundle.meta.local.schema.json",
  "title": "lp.incident.bundle.meta.local@0.1.0",
  "description": "Local companion schema for the meta object stored with lp.incident.bundle@0.1.0 and for the materialized incident.meta.local.json file in Phase C.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "classification",
    "source",
    "incident_status",
    "deployment_id",
    "run_id",
    "target",
    "captured_unix_ms"
  ],
  "properties": {
    "schema_version": {
      "const": "lp.incident.bundle.meta.local@0.1.0"
    },
    "classification": {
      "type": "string",
      "enum": [
        "http_5xx",
        "runtime_start_failed",
        "runtime_health_failed",
        "slo_rollback",
        "manual_capture",
        "app_kill",
        "platform_kill"
      ]
    },
    "source": {
      "type": "string",
      "enum": [
        "router",
        "runtime",
        "slo",
        "manual",
        "control_plane"
      ]
    },
    "incident_status": {
      "type": "string",
      "enum": [
        "open",
        "regression_generated",
        "resolved"
      ]
    },
    "deployment_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "app_id",
        "environment"
      ],
      "properties": {
        "app_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "environment": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z][a-z0-9_-]{0,63}$"
        }
      }
    },
    "captured_unix_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991,
      "description": "Unix timestamp in milliseconds (non-negative, JS-safe integer)."
    },
    "request_id": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "trace_id": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "pack_digest": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "sha256",
            "bytes_len"
          ],
          "properties": {
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "bytes_len": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "slot": {
      "type": "string",
      "enum": [
        "stable",
        "candidate",
        "none"
      ],
      "default": "none"
    },
    "candidate_weight_pct": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "status_code": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "route_key": {
      "oneOf": [
        {
          "type": "string",
          "maxLength": 512
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "decision_id": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "regression_id": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "regression_status": {
      "type": "string",
      "enum": [
        "not_requested",
        "requested",
        "generated",
        "failed",
        "unavailable"
      ],
      "default": "not_requested"
    },
    "signature_status": {
      "type": "string",
      "enum": [
        "valid",
        "missing",
        "invalid",
        "not_applicable"
      ]
    }
  }
}
