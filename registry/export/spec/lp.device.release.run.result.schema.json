{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.device.release.run.result.schema.json",
  "title": "lp.device.release.run.result@0.2.0",
  "description": "Result shape embedded in lp.cli.report.result for x07lp device release run, including the normalized native summary and latest native health status.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "exec_id",
    "plan_id",
    "provider_kind",
    "target",
    "status",
    "decision_count",
    "native_summary",
    "release_readiness",
    "latest_native_health_rollup",
    "latest_native_incident_id",
    "latest_regression_id",
    "latest_regression_status",
    "execution"
  ],
  "properties": {
    "schema_version": {
      "const": "lp.device.release.run.result@0.2.0"
    },
    "exec_id": { "$ref": "#/$defs/id" },
    "plan_id": { "$ref": "#/$defs/id" },
    "provider_kind": { "$ref": "#/$defs/provider_kind" },
    "target": { "$ref": "#/$defs/release_target" },
    "status": {
      "type": "string",
      "enum": ["planned", "started", "completed", "failed", "aborted"]
    },
    "decision_count": {
      "type": "integer",
      "minimum": 0
    },
    "native_summary": { "$ref": "#/$defs/native_summary" },
    "release_readiness": { "$ref": "#/$defs/release_readiness" },
    "latest_native_health_rollup": {
      "oneOf": [
        { "$ref": "#/$defs/native_health_rollup" },
        { "type": "null" }
      ],
      "default": null
    },
    "latest_native_incident_id": {
      "oneOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }],
      "default": null
    },
    "latest_regression_id": {
      "oneOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }],
      "default": null
    },
    "latest_regression_status": { "$ref": "#/$defs/regression_status" },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "digest"],
      "properties": {
        "kind": { "const": "lp.device.release.execution@0.2.0" },
        "digest": { "$ref": "#/$defs/digest_ref" }
      }
    },
    "run_id": { "$ref": "#/$defs/id" }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "digest_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256", "bytes_len"],
      "properties": {
        "sha256": { "$ref": "#/$defs/sha256" },
        "bytes_len": { "type": "integer", "minimum": 0 }
      }
    },
    "release_target": {
      "type": "string",
      "enum": ["ios", "android"]
    },
    "provider_kind": {
      "type": "string",
      "enum": ["mock_v1", "appstoreconnect_v1", "googleplay_v1"]
    },
    "permission_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z][a-z0-9._-]*$"
    },
    "telemetry_class": {
      "type": "string",
      "enum": [
        "app.lifecycle",
        "app.http",
        "runtime.error",
        "bridge.timing",
        "reducer.timing",
        "policy.violation",
        "host.webview_crash"
      ]
    },
    "blob_store_capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "max_total_bytes", "max_item_bytes"],
      "properties": {
        "enabled": { "type": "boolean" },
        "max_total_bytes": { "type": "integer", "minimum": 1, "maximum": 1073741824 },
        "max_item_bytes": { "type": "integer", "minimum": 1, "maximum": 268435456 }
      }
    },
    "native_capability_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "camera_photo",
        "files_pick",
        "blob_store",
        "location_foreground",
        "notifications_local",
        "notifications_push"
      ],
      "properties": {
        "camera_photo": { "type": "boolean" },
        "files_pick": { "type": "boolean" },
        "blob_store": { "$ref": "#/$defs/blob_store_capability" },
        "location_foreground": { "type": "boolean" },
        "notifications_local": { "type": "boolean" },
        "notifications_push": { "type": "boolean" }
      }
    },
    "native_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_kind",
        "provider_kind",
        "package_manifest_sha256",
        "capabilities",
        "permission_declarations",
        "telemetry_classes"
      ],
      "properties": {
        "target_kind": { "$ref": "#/$defs/release_target" },
        "provider_kind": { "$ref": "#/$defs/provider_kind" },
        "package_manifest_sha256": { "$ref": "#/$defs/sha256" },
        "capabilities": { "$ref": "#/$defs/native_capability_summary" },
        "permission_declarations": {
          "type": "array",
          "minItems": 0,
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/permission_id" }
        },
        "telemetry_classes": {
          "type": "array",
          "minItems": 0,
          "maxItems": 16,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/telemetry_class" }
        }
      }
    },
    "readiness_issue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[A-Z][A-Z0-9_-]*$"
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "field": {
          "type": "string",
          "maxLength": 256
        }
      }
    },
    "release_readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "warnings", "errors"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ok", "warn", "blocked"]
        },
        "warnings": {
          "type": "array",
          "maxItems": 128,
          "items": { "$ref": "#/$defs/readiness_issue" },
          "default": []
        },
        "errors": {
          "type": "array",
          "maxItems": 128,
          "items": { "$ref": "#/$defs/readiness_issue" },
          "default": []
        }
      }
    },
    "native_health_rollup": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "native_runtime_error_count",
        "native_policy_violation_count",
        "native_bridge_timeout_count",
        "native_host_crash_count",
        "native_permission_blocked_count",
        "last_native_event_unix_ms"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["unknown", "healthy", "degraded", "failed"]
        },
        "native_runtime_error_count": { "type": "integer", "minimum": 0 },
        "native_policy_violation_count": { "type": "integer", "minimum": 0 },
        "native_bridge_timeout_count": { "type": "integer", "minimum": 0 },
        "native_host_crash_count": { "type": "integer", "minimum": 0 },
        "native_permission_blocked_count": { "type": "integer", "minimum": 0 },
        "last_native_event_unix_ms": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      }
    },
    "regression_status": {
      "type": "string",
      "enum": ["not_requested", "requested", "generated", "failed", "unavailable"]
    }
  }
}
