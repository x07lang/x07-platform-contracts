{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.workload.list.result.schema.json",
  "title": "lp.workload.list.result@0.1.0",
  "description": "List view for workloads in CLI, UI, and MCP surfaces.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "view",
    "items",
    "generated_unix_ms"
  ],
  "properties": {
    "schema_version": {
      "const": "lp.workload.list.result@0.1.0"
    },
    "view": {
      "const": "list"
    },
    "filters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "org_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "project_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "environment_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        }
      },
      "default": {}
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "workload_id",
          "display_name",
          "cell_count",
          "latest_release_id",
          "updated_unix_ms"
        ],
        "properties": {
          "workload_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "display_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "cell_count": {
            "type": "integer",
            "minimum": 1
          },
          "latest_release_id": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "health": {
            "type": "string",
            "enum": [
              "unknown",
              "healthy",
              "degraded",
              "failed"
            ]
          },
          "updated_unix_ms": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          }
        }
      }
    },
    "generated_unix_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    }
  }
}
