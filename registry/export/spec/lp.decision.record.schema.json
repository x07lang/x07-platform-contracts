{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.decision.record.schema.json",
  "title": "lp.decision.record@0.1.0",
  "description": "Platform decision record. Every gate outcome is recorded with reasons and evidence. Signatures are optional in v0.1.0 (reserved for kill-switch/audit hardening).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision_id",
    "run_id",
    "created_unix_ms",
    "kind",
    "outcome",
    "reasons",
    "evidence",
    "integrity"
  ],
  "properties": {
    "schema_version": { "const": "lp.decision.record@0.1.0" },
    "decision_id": { "$ref": "#/$defs/id" },
    "run_id": { "$ref": "#/$defs/id" },
    "created_unix_ms": { "$ref": "#/$defs/unix_ms" },
    "kind": { "$ref": "#/$defs/decision_kind" },
    "outcome": { "$ref": "#/$defs/outcome" },
    "reasons": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": { "$ref": "#/$defs/reason" }
    },
    "evidence": {
      "type": "array",
      "maxItems": 512,
      "items": { "$ref": "#/$defs/artifact_ref" },
      "default": []
    },
    "subject": {
      "type": ["object", "null"],
      "default": null,
      "additionalProperties": false,
      "required": ["artifact"],
      "properties": { "artifact": { "$ref": "#/$defs/artifact_ref" } }
    },
    "integrity": { "$ref": "#/$defs/integrity" },
    "meta": { "type": "object", "additionalProperties": true, "default": {} }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "bytes_len": { "type": "integer", "minimum": 0 },
    "unix_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991,
      "description": "Unix timestamp in milliseconds (non-negative, JS-safe integer)."
    },
    "schema_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*@[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Schema identifier like 'x07.app.pack@0.1.0'."
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sig"],
      "properties": {
        "keyid": { "type": "string", "minLength": 1, "maxLength": 512 },
        "sig": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048,
          "pattern": "^[A-Za-z0-9+/]+={0,2}$",
          "description": "Base64 signature bytes."
        }
      }
    },
    "digest_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256", "bytes_len"],
      "properties": {
        "sha256": { "$ref": "#/$defs/sha256" },
        "bytes_len": { "$ref": "#/$defs/bytes_len" }
      }
    },
    "artifact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["digest"],
      "properties": {
        "kind": { "$ref": "#/$defs/schema_id" },
        "digest": { "$ref": "#/$defs/digest_ref" },
        "label": { "type": "string", "maxLength": 256 }
      }
    },
    "outcome": { "type": "string", "enum": ["allow", "deny", "error"] },
    "reason_code": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Z][A-Z0-9_-]*$",
      "description": "Stable reason code."
    },
    "reason": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code"],
      "properties": {
        "code": { "$ref": "#/$defs/reason_code" },
        "message": { "type": "string", "maxLength": 1024 }
      }
    },
    "decision_kind": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z][a-z0-9._-]*$",
      "description": "Decision kind identifier (e.g., 'intake.accept')."
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_sha256", "signatures"],
      "properties": {
        "record_sha256": {
          "$ref": "#/$defs/sha256",
          "description": "sha256 of canonical decision record with signatures omitted/empty."
        },
        "signatures": {
          "type": "array",
          "maxItems": 16,
          "items": { "$ref": "#/$defs/signature" },
          "default": []
        }
      }
    }
  }
}
