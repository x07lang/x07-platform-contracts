{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.regression.run.result.schema.json",
  "title": "lp.regression.run.result@0.1.0",
  "description": "Result object for x07lp regress from-incident and the corresponding MCP/UI action surfaces.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "incident_id",
    "regression_id",
    "ok",
    "tool",
    "incident_status_after",
    "generated"
  ],
  "properties": {
    "schema_version": {
      "const": "lp.regression.run.result@0.1.0"
    },
    "incident_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "regression_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "ok": {
      "type": "boolean"
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "command"
      ],
      "properties": {
        "name": {
          "type": "string",
          "const": "x07-wasm"
        },
        "command": {
          "type": "string",
          "const": "app regress from-incident"
        }
      }
    },
    "dry_run": {
      "type": "boolean",
      "default": false
    },
    "out_dir": {
      "oneOf": [
        {
          "type": "string",
          "maxLength": 1024
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "incident_status_after": {
      "type": "string",
      "enum": [
        "not_requested",
        "requested",
        "generated",
        "failed",
        "unavailable"
      ]
    },
    "target_artifact": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "digest"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "minLength": 3,
              "maxLength": 128,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*@[0-9]+\\.[0-9]+\\.[0-9]+$"
            },
            "digest": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "sha256",
                "bytes_len"
              ],
              "properties": {
                "sha256": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{64}$"
                },
                "bytes_len": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            },
            "label": {
              "type": "string",
              "maxLength": 256
            },
            "store_uri": {
              "type": "string",
              "maxLength": 2048
            },
            "media_type": {
              "type": "string",
              "maxLength": 256
            },
            "logical_name": {
              "type": "string",
              "maxLength": 256
            }
          }
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "request": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "digest"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "minLength": 3,
              "maxLength": 128,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*@[0-9]+\\.[0-9]+\\.[0-9]+$"
            },
            "digest": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "sha256",
                "bytes_len"
              ],
              "properties": {
                "sha256": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{64}$"
                },
                "bytes_len": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            },
            "label": {
              "type": "string",
              "maxLength": 256
            },
            "store_uri": {
              "type": "string",
              "maxLength": 2048
            },
            "media_type": {
              "type": "string",
              "maxLength": 256
            },
            "logical_name": {
              "type": "string",
              "maxLength": 256
            }
          }
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "report": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "digest"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "minLength": 3,
              "maxLength": 128,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*@[0-9]+\\.[0-9]+\\.[0-9]+$"
            },
            "digest": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "sha256",
                "bytes_len"
              ],
              "properties": {
                "sha256": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{64}$"
                },
                "bytes_len": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            },
            "label": {
              "type": "string",
              "maxLength": 256
            },
            "store_uri": {
              "type": "string",
              "maxLength": 2048
            },
            "media_type": {
              "type": "string",
              "maxLength": 256
            },
            "logical_name": {
              "type": "string",
              "maxLength": 256
            }
          }
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "generated": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role",
          "digest",
          "media_type",
          "store_uri"
        ],
        "properties": {
          "role": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          },
          "ord": {
            "type": "integer",
            "minimum": 0,
            "default": 0
          },
          "kind": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 3,
                "maxLength": 128,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*@[0-9]+\\.[0-9]+\\.[0-9]+$"
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "digest": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "sha256",
              "bytes_len"
            ],
            "properties": {
              "sha256": {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              },
              "bytes_len": {
                "type": "integer",
                "minimum": 0
              }
            }
          },
          "media_type": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "logical_name": {
            "type": "string",
            "maxLength": 256
          },
          "store_uri": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2048
          }
        }
      },
      "default": []
    }
  }
}
