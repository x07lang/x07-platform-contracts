{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.deploy.query.result.schema.json",
  "title": "lp.deploy.query.result@0.1.0",
  "description": "Result object for x07lp deploy query and the corresponding MCP/UI surfaces. Phase C extends the Phase B query contract with control-state, kill, incident, and signature fields.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "view",
    "deployment_id",
    "run_id",
    "target",
    "resolution",
    "index"
  ],
  "properties": {
    "schema_version": {
      "const": "lp.deploy.query.result@0.1.0"
    },
    "view": {
      "type": "string",
      "enum": [
        "summary",
        "timeline",
        "decisions",
        "artifacts",
        "full"
      ]
    },
    "deployment_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "app_id",
        "environment"
      ],
      "properties": {
        "app_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "environment": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z][a-z0-9_-]{0,63}$"
        }
      }
    },
    "resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "by"
      ],
      "properties": {
        "by": {
          "type": "string",
          "enum": [
            "deployment_id",
            "latest"
          ]
        },
        "requested_deployment_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "requested_target": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "app_id",
            "environment"
          ],
          "properties": {
            "app_id": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
            },
            "environment": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64,
              "pattern": "^[a-z][a-z0-9_-]{0,63}$"
            }
          }
        }
      },
      "default": {
        "by": "deployment_id"
      }
    },
    "index": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "used",
        "rebuilt",
        "db_path"
      ],
      "properties": {
        "used": {
          "type": "boolean"
        },
        "rebuilt": {
          "type": "boolean"
        },
        "db_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "started",
        "completed",
        "failed",
        "aborted"
      ]
    },
    "outcome": {
      "type": "string",
      "enum": [
        "unknown",
        "promoted",
        "rolled_back",
        "aborted",
        "failed"
      ]
    },
    "created_unix_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991,
      "description": "Unix timestamp in milliseconds (non-negative, JS-safe integer)."
    },
    "updated_unix_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991,
      "description": "Unix timestamp in milliseconds (non-negative, JS-safe integer)."
    },
    "current_weight_pct": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "public_listener": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "latest_decision_id": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "latest_signed_control_decision_id": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "signature_status": {
      "type": "string",
      "enum": [
        "valid",
        "missing",
        "invalid",
        "not_applicable"
      ]
    },
    "plan_digest": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "sha256",
            "bytes_len"
          ],
          "properties": {
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "bytes_len": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "stable_revision": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "sha256",
            "bytes_len"
          ],
          "properties": {
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "bytes_len": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "candidate_revision": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "sha256",
            "bytes_len"
          ],
          "properties": {
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "bytes_len": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "control_state": {
      "type": "string",
      "enum": [
        "active",
        "paused",
        "stopping",
        "killed",
        "terminal"
      ]
    },
    "kill_scope": {
      "type": "string",
      "enum": [
        "none",
        "app",
        "platform"
      ]
    },
    "kill_latched": {
      "type": "boolean"
    },
    "incident_count_total": {
      "type": "integer",
      "minimum": 0
    },
    "incident_count_open": {
      "type": "integer",
      "minimum": 0
    },
    "last_incident_id": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "idx",
          "name",
          "status",
          "started_unix_ms",
          "ended_unix_ms",
          "decisions"
        ],
        "properties": {
          "idx": {
            "type": "integer",
            "minimum": 0
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "kind": {
            "type": "string",
            "maxLength": 64
          },
          "status": {
            "type": "string",
            "enum": [
              "ok",
              "error",
              "skipped",
              "running"
            ]
          },
          "started_unix_ms": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991,
            "description": "Unix timestamp in milliseconds (non-negative, JS-safe integer)."
          },
          "ended_unix_ms": {
            "oneOf": [
              {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991,
                "description": "Unix timestamp in milliseconds (non-negative, JS-safe integer)."
              },
              {
                "type": "null"
              }
            ]
          },
          "attempt": {
            "type": "integer",
            "minimum": 1,
            "default": 1
          },
          "latest_weight_pct": {
            "oneOf": [
              {
                "type": "integer",
                "minimum": 0,
                "maximum": 100
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "analysis_decision": {
            "oneOf": [
              {
                "type": "string",
                "enum": [
                  "promote",
                  "rollback",
                  "inconclusive"
                ]
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "control_state": {
            "oneOf": [
              {
                "type": "string",
                "enum": [
                  "active",
                  "paused",
                  "stopping",
                  "killed",
                  "terminal"
                ]
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "decisions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
            },
            "default": []
          }
        }
      },
      "default": []
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "decision_id",
          "created_unix_ms",
          "kind",
          "outcome",
          "reasons",
          "record"
        ],
        "properties": {
          "decision_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
          },
          "created_unix_ms": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991,
            "description": "Unix timestamp in milliseconds (non-negative, JS-safe integer)."
          },
          "step_idx": {
            "oneOf": [
              {
                "type": "integer",
                "minimum": 0
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "kind": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^[a-z][a-z0-9._-]*$"
          },
          "outcome": {
            "type": "string",
            "enum": [
              "allow",
              "deny",
              "error"
            ]
          },
          "reasons": {
            "type": "array",
            "minItems": 1,
            "maxItems": 64,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "code"
              ],
              "properties": {
                "code": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 64,
                  "pattern": "^[A-Z][A-Z0-9_-]*$"
                },
                "message": {
                  "type": "string",
                  "maxLength": 1024
                }
              }
            }
          },
          "evidence": {
            "type": "array",
            "maxItems": 512,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "role",
                "digest",
                "media_type",
                "store_uri"
              ],
              "properties": {
                "role": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 64
                },
                "ord": {
                  "type": "integer",
                  "minimum": 0,
                  "default": 0
                },
                "kind": {
                  "oneOf": [
                    {
                      "type": "string",
                      "minLength": 3,
                      "maxLength": 128,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*@[0-9]+\\.[0-9]+\\.[0-9]+$"
                    },
                    {
                      "type": "null"
                    }
                  ],
                  "default": null
                },
                "digest": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "sha256",
                    "bytes_len"
                  ],
                  "properties": {
                    "sha256": {
                      "type": "string",
                      "pattern": "^[0-9a-f]{64}$"
                    },
                    "bytes_len": {
                      "type": "integer",
                      "minimum": 0
                    }
                  }
                },
                "media_type": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256
                },
                "logical_name": {
                  "type": "string",
                  "maxLength": 256
                },
                "store_uri": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 2048
                }
              }
            },
            "default": []
          },
          "record": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "digest",
              "store_uri"
            ],
            "properties": {
              "digest": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "sha256",
                  "bytes_len"
                ],
                "properties": {
                  "sha256": {
                    "type": "string",
                    "pattern": "^[0-9a-f]{64}$"
                  },
                  "bytes_len": {
                    "type": "integer",
                    "minimum": 0
                  }
                }
              },
              "store_uri": {
                "type": "string",
                "maxLength": 2048
              },
              "media_type": {
                "type": "string",
                "maxLength": 256,
                "default": "application/json"
              },
              "kind": {
                "type": "string",
                "const": "lp.decision.record@0.1.0"
              }
            }
          },
          "signature_status": {
            "type": "string",
            "enum": [
              "valid",
              "missing",
              "invalid",
              "not_applicable"
            ]
          }
        }
      },
      "default": []
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role",
          "digest",
          "media_type",
          "store_uri"
        ],
        "properties": {
          "role": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          },
          "ord": {
            "type": "integer",
            "minimum": 0,
            "default": 0
          },
          "kind": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 3,
                "maxLength": 128,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*@[0-9]+\\.[0-9]+\\.[0-9]+$"
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "digest": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "sha256",
              "bytes_len"
            ],
            "properties": {
              "sha256": {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              },
              "bytes_len": {
                "type": "integer",
                "minimum": 0
              }
            }
          },
          "media_type": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "logical_name": {
            "type": "string",
            "maxLength": 256
          },
          "store_uri": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2048
          }
        }
      },
      "default": []
    },
    "linked_incidents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "incident_id",
          "classification",
          "incident_status",
          "captured_unix_ms"
        ],
        "properties": {
          "incident_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
          },
          "classification": {
            "type": "string",
            "enum": [
              "http_5xx",
              "runtime_start_failed",
              "runtime_health_failed",
              "slo_rollback",
              "manual_capture",
              "app_kill",
              "platform_kill"
            ]
          },
          "incident_status": {
            "type": "string",
            "enum": [
              "open",
              "regression_generated",
              "resolved"
            ]
          },
          "captured_unix_ms": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991,
            "description": "Unix timestamp in milliseconds (non-negative, JS-safe integer)."
          }
        }
      },
      "default": []
    },
    "execution": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "schema_version",
            "exec_id",
            "run_id",
            "created_unix_ms",
            "status"
          ],
          "properties": {
            "schema_version": {
              "const": "lp.deploy.execution@0.1.0"
            },
            "exec_id": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
            },
            "run_id": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
            },
            "created_unix_ms": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991,
              "description": "Unix timestamp in milliseconds (non-negative, JS-safe integer)."
            },
            "status": {
              "type": "string",
              "enum": [
                "planned",
                "started",
                "completed",
                "failed",
                "aborted"
              ]
            }
          }
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "oneOf": [
    {
      "title": "summary view",
      "properties": {
        "view": {
          "const": "summary"
        }
      },
      "required": [
        "schema_version",
        "view",
        "deployment_id",
        "run_id",
        "target",
        "resolution",
        "index",
        "status",
        "outcome",
        "created_unix_ms",
        "updated_unix_ms",
        "current_weight_pct",
        "public_listener",
        "latest_decision_id",
        "latest_signed_control_decision_id",
        "signature_status",
        "plan_digest",
        "stable_revision",
        "candidate_revision",
        "control_state",
        "kill_scope",
        "kill_latched",
        "incident_count_total",
        "incident_count_open",
        "last_incident_id"
      ]
    },
    {
      "title": "timeline view",
      "properties": {
        "view": {
          "const": "timeline"
        }
      },
      "required": [
        "schema_version",
        "view",
        "deployment_id",
        "run_id",
        "target",
        "resolution",
        "index",
        "steps"
      ]
    },
    {
      "title": "decisions view",
      "properties": {
        "view": {
          "const": "decisions"
        }
      },
      "required": [
        "schema_version",
        "view",
        "deployment_id",
        "run_id",
        "target",
        "resolution",
        "index",
        "decisions"
      ]
    },
    {
      "title": "artifacts view",
      "properties": {
        "view": {
          "const": "artifacts"
        }
      },
      "required": [
        "schema_version",
        "view",
        "deployment_id",
        "run_id",
        "target",
        "resolution",
        "index",
        "artifacts"
      ]
    },
    {
      "title": "full view",
      "properties": {
        "view": {
          "const": "full"
        }
      },
      "required": [
        "schema_version",
        "view",
        "deployment_id",
        "run_id",
        "target",
        "resolution",
        "index",
        "status",
        "outcome",
        "created_unix_ms",
        "updated_unix_ms",
        "current_weight_pct",
        "public_listener",
        "latest_decision_id",
        "latest_signed_control_decision_id",
        "signature_status",
        "plan_digest",
        "stable_revision",
        "candidate_revision",
        "control_state",
        "kill_scope",
        "kill_latched",
        "incident_count_total",
        "incident_count_open",
        "last_incident_id",
        "steps",
        "decisions",
        "artifacts",
        "execution"
      ]
    }
  ]
}
