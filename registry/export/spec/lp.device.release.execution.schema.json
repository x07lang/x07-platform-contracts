{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.device.release.execution.schema.json",
  "title": "lp.device.release.execution@0.1.0",
  "description": "Run record for executing an lp.device.release.plan and recording provider-neutral release state.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "exec_id",
    "plan_id",
    "run_id",
    "created_unix_ms",
    "status",
    "steps",
    "meta"
  ],
  "properties": {
    "schema_version": { "const": "lp.device.release.execution@0.1.0" },
    "exec_id": { "$ref": "#/$defs/id" },
    "plan_id": { "$ref": "#/$defs/id" },
    "run_id": { "$ref": "#/$defs/id" },
    "created_unix_ms": { "$ref": "#/$defs/unix_ms" },
    "status": { "$ref": "#/$defs/exec_status" },
    "plan": {
      "oneOf": [{ "$ref": "#/$defs/plan_ref" }, { "type": "null" }],
      "default": null
    },
    "steps": {
      "type": "array",
      "maxItems": 4096,
      "items": { "$ref": "#/$defs/exec_step" },
      "default": []
    },
    "meta": {
      "type": "object",
      "required": [
        "provider_kind",
        "distribution_lane",
        "target",
        "package_digest",
        "current_state",
        "current_rollout_percent",
        "latest_store_release_id"
      ],
      "additionalProperties": true,
      "properties": {
        "provider_kind": {
          "type": "string",
          "enum": ["mock_v1", "appstoreconnect_v1", "googleplay_v1"]
        },
        "distribution_lane": {
          "type": "string",
          "enum": ["beta", "production"]
        },
        "target": {
          "type": "string",
          "enum": ["ios", "android"]
        },
        "package_digest": { "$ref": "#/$defs/digest_ref" },
        "current_state": {
          "type": "string",
          "enum": [
            "draft",
            "review",
            "available",
            "in_progress",
            "paused",
            "halted",
            "completed",
            "rolled_back"
          ]
        },
        "current_rollout_percent": {
          "oneOf": [
            { "type": "integer", "minimum": 0, "maximum": 100 },
            { "type": "null" }
          ],
          "default": null
        },
        "latest_store_release_id": {
          "oneOf": [
            { "type": "string", "minLength": 1, "maxLength": 256 },
            { "type": "null" }
          ],
          "default": null
        }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "bytes_len": { "type": "integer", "minimum": 0 },
    "unix_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991,
      "description": "Unix timestamp in milliseconds (non-negative, JS-safe integer)."
    },
    "digest_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256", "bytes_len"],
      "properties": {
        "sha256": { "$ref": "#/$defs/sha256" },
        "bytes_len": { "$ref": "#/$defs/bytes_len" }
      }
    },
    "schema_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*@[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "artifact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["digest"],
      "properties": {
        "kind": { "$ref": "#/$defs/schema_id" },
        "digest": { "$ref": "#/$defs/digest_ref" },
        "label": { "type": "string", "maxLength": 256 }
      }
    },
    "exec_status": {
      "type": "string",
      "enum": ["planned", "started", "completed", "failed", "aborted"]
    },
    "plan_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "digest"],
      "properties": {
        "kind": { "const": "lp.device.release.plan@0.1.0" },
        "digest": { "$ref": "#/$defs/digest_ref" }
      }
    },
    "exec_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["idx", "status", "started_unix_ms", "ended_unix_ms"],
      "properties": {
        "idx": { "type": "integer", "minimum": 0 },
        "name": { "type": "string", "maxLength": 128 },
        "kind": { "type": "string", "maxLength": 128 },
        "status": { "type": "string", "enum": ["ok", "error", "skipped", "running"] },
        "started_unix_ms": { "$ref": "#/$defs/unix_ms" },
        "ended_unix_ms": {
          "oneOf": [{ "$ref": "#/$defs/unix_ms" }, { "type": "null" }],
          "default": null
        },
        "attempt": { "type": "integer", "minimum": 1, "default": 1 },
        "latest_rollout_percent": {
          "oneOf": [
            { "type": "integer", "minimum": 0, "maximum": 100 },
            { "type": "null" }
          ],
          "default": null
        },
        "store_release_id": {
          "oneOf": [
            { "type": "string", "minLength": 1, "maxLength": 256 },
            { "type": "null" }
          ],
          "default": null
        },
        "decisions": {
          "type": "array",
          "maxItems": 128,
          "items": { "$ref": "#/$defs/id" },
          "default": []
        },
        "evidence": {
          "type": "array",
          "maxItems": 256,
          "items": { "$ref": "#/$defs/artifact_ref" },
          "default": []
        }
      }
    }
  }
}
