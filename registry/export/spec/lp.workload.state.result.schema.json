{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.workload.state.result.schema.json",
  "title": "lp.workload.state.result@0.1.0",
  "description": "Desired and observed workload state used by runtime, UI, CLI, and hosted control surfaces.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workload_id",
    "desired",
    "observed",
    "generated_unix_ms"
  ],
  "properties": {
    "schema_version": {
      "const": "lp.workload.state.result@0.1.0"
    },
    "workload_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "target_id": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "desired": {
      "$ref": "#/$defs/desired_state"
    },
    "observed": {
      "$ref": "#/$defs/observed_state"
    },
    "generated_unix_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    }
  },
  "$defs": {
    "replica_count": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 0
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "unix_ms": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "desired_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "updated_unix_ms"
      ],
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "running",
            "paused",
            "stopped",
            "deleted"
          ]
        },
        "release_id": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "deployment_id": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "rollout_strategy": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 64
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "updated_unix_ms": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      }
    },
    "observed_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "health",
        "cells",
        "updated_unix_ms"
      ],
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "unknown",
            "pending",
            "running",
            "degraded",
            "failed",
            "stopped"
          ]
        },
        "health": {
          "type": "string",
          "enum": [
            "unknown",
            "healthy",
            "degraded",
            "failed"
          ]
        },
        "release_id": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "deployment_id": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "message": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 1024
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "cells": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/cell_state"
          },
          "default": []
        },
        "updated_unix_ms": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      }
    },
    "cell_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cell_key",
        "state",
        "health"
      ],
      "properties": {
        "cell_key": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "state": {
          "type": "string",
          "enum": [
            "unknown",
            "pending",
            "running",
            "degraded",
            "failed",
            "stopped"
          ]
        },
        "health": {
          "type": "string",
          "enum": [
            "unknown",
            "healthy",
            "degraded",
            "failed"
          ]
        },
        "desired_replicas": {
          "$ref": "#/$defs/replica_count"
        },
        "ready_replicas": {
          "$ref": "#/$defs/replica_count"
        },
        "route_url": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 2048
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "last_run_unix_ms": {
          "$ref": "#/$defs/unix_ms"
        },
        "next_run_unix_ms": {
          "$ref": "#/$defs/unix_ms"
        },
        "message": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 1024
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      }
    }
  }
}
